#!/usr/bin/env python3
import http.server, socketserver, os, datetime

PORT = int(os.environ["HEALTH_PORT"])
LOGDIR = "/var/log/healthapp"
LOGFILE = os.path.join(LOGDIR, "app.log")

REQUESTS = 0

def log(msg):
    ts = datetime.datetime.now().isoformat(timespec="seconds")
    with open(LOGFILE, "a") as f:
        f.write(f"{ts} {msg}\n")

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        global REQUESTS
        if self.path == "/metrics":
            body = (
                "# HELP healthapp_requests_total Total HTTP requests\n"
                "# TYPE healthapp_requests_total counter\n"
                f"healthapp_requests_total {REQUESTS}\n"
            ).encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/plain")
            self.end_headers()
            self.wfile.write(body)
            return
        REQUESTS += 1
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.end_headers()
        self.wfile.write(b"OK\n")
        log(f"GET {self.path} -> 200")
    def log_message(self, *args):
        pass

log("starting")
with socketserver.TCPServer(("127.0.0.1", PORT), Handler) as httpd:
    log(f"listening on 127.0.0.1:{PORT}")
    httpd.serve_forever()
